# ==============================================================================
# Riva ASR Configuration
# ==============================================================================
# This file contains all configuration options for connecting to NVIDIA Riva
# Copy this file to .env and fill in your actual credentials
# 
# IMPORTANT: Never commit your actual .env file to version control!
# ==============================================================================

# ------------------------------------------------------------------------------
# Deployment Type
# ------------------------------------------------------------------------------
# Options: nvcf | self-hosted | cloud
# - nvcf: NVIDIA Cloud Functions (requires bearer token and function IDs)
# - self-hosted: Your own Riva server (minimal authentication)
# - cloud: Cloud-hosted Riva (may use API key or bearer token)
# ------------------------------------------------------------------------------
RIVA_DEPLOYMENT_TYPE=nvcf

# ------------------------------------------------------------------------------
# Connection Settings (Required for all deployment types)
# ------------------------------------------------------------------------------
RIVA_USE_SSL=true
RIVA_URI=grpc.nvcf.nvidia.com:443

# ==============================================================================
# NVCF Configuration (only needed when RIVA_DEPLOYMENT_TYPE=nvcf)
# ==============================================================================
# Get these credentials from NVIDIA Cloud Functions console
# https://build.nvidia.com/
# ------------------------------------------------------------------------------
RIVA_BEARER_TOKEN=nvapi-your-token-here
RIVA_FUNCTION_ID=your-function-id-here
RIVA_FUNCTION_VERSION_ID=your-function-version-id-here

# ==============================================================================
# Self-Hosted Configuration (only needed when RIVA_DEPLOYMENT_TYPE=self-hosted)
# ==============================================================================
# Uncomment and configure these if you're running your own Riva server
# ------------------------------------------------------------------------------
# RIVA_URI=localhost:50051
# RIVA_USE_SSL=false
# 
# Optional: If your self-hosted Riva uses SSL, provide certificate path
# RIVA_SSL_CERT=/app/certs/riva-server.pem
# 
# Optional: If your self-hosted Riva requires authentication
# RIVA_API_KEY=your-api-key

# ==============================================================================
# Cloud Deployment Configuration (only needed when RIVA_DEPLOYMENT_TYPE=cloud)
# ==============================================================================
# Configure these if you're using a cloud-hosted Riva instance
# (e.g., AWS, Azure, GCP, or other cloud provider)
# ------------------------------------------------------------------------------
# RIVA_URI=riva.yourcompany.com:443
# RIVA_USE_SSL=true
# 
# Option 1: API Key authentication
# RIVA_API_KEY=your-api-key-here
# 
# Option 2: Bearer Token authentication (alternative to API key)
# RIVA_BEARER_TOKEN=your-bearer-token-here
# 
# Optional: SSL certificate if required
# RIVA_SSL_CERT=/app/certs/cloud-riva.pem

# ==============================================================================
# LLM Configuration (Required for Q&A and Speaker Naming Features)
# ==============================================================================
# Used for the question-answering feature and automatic speaker name assignment
# Supports OpenAI-compatible APIs
# ------------------------------------------------------------------------------
BASE_URL=https://llms.flashlit.ai:5000/v1
MODEL_NAME=nvcf-gpt-oss-120b
OPENAI_API_KEY=your-openai-api-key-here

# ==============================================================================
# Configuration Examples
# ==============================================================================
# 
# Example 1: NVCF (Default)
# --------------------------
# RIVA_DEPLOYMENT_TYPE=nvcf
# RIVA_USE_SSL=true
# RIVA_URI=grpc.nvcf.nvidia.com:443
# RIVA_BEARER_TOKEN=nvapi-xxxxx
# RIVA_FUNCTION_ID=4f9cd9c1-xxxx
# RIVA_FUNCTION_VERSION_ID=6f3f6b2e-xxxx
# 
# Example 2: Local Self-Hosted (No Authentication)
# -------------------------------------------------
# RIVA_DEPLOYMENT_TYPE=self-hosted
# RIVA_USE_SSL=false
# RIVA_URI=localhost:50051
# 
# Example 3: Self-Hosted with SSL and API Key
# --------------------------------------------
# RIVA_DEPLOYMENT_TYPE=self-hosted
# RIVA_USE_SSL=true
# RIVA_URI=riva.internal.company.com:50051
# RIVA_SSL_CERT=/app/certs/riva-server.pem
# RIVA_API_KEY=internal-api-key-12345
# 
# Example 4: Cloud Provider with API Key
# ---------------------------------------
# RIVA_DEPLOYMENT_TYPE=cloud
# RIVA_USE_SSL=true
# RIVA_URI=riva.yourcompany.com:443
# RIVA_API_KEY=cloud-api-key-67890
# 
# ==============================================================================
